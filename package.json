{
  "name": "task-manager-backend",
  "version": "1.0.0",
  "description": "Backend API for Task Manager application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test-server": "node test-server.js",
    "test-docs": "node test-server.js",
    "install:deps": "npm install",
    "docs": "echo \"Swagger documentation available at http://localhost:3000/api-docs\"",
    "init-db": "node src/config/init-db.js",
    "db:reset": "node -e \"require('./src/config/postgres').sequelize.sync({force: true}).then(() => process.exit(0))\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "task-manager",
    "backend",
    "api",
    "express",
    "postgresql",
    "sequelize"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "sequelize": "^6.35.1",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
